MONGO_URI=mongodb://localhost:27017/alphacure
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY=7d

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google Maps (Nearby Hospitals)
# 1. Enable Places API in Google Cloud Console
# 2. Create an API key and paste it below (keep server-side only — do not commit real keys)
# 3. Restart the Flask backend after updating backend/.env
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Razorpay (Doctor consultation Rs. 5) — https://dashboard.razorpay.com/
# Use Test Mode keys for development. Restart backend after updating.
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
CONSULTATION_AMOUNT_INR=5

FLASK_ENV=development
FRONTEND_URL=http://localhost:3000
